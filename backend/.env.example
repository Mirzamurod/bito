PORT=4000
# Local MongoDB (standalone — transaction lar ishlamaydi, kod avtomatik fallback qiladi)
MONGODB_URI=mongodb://localhost:27017/bito?retryWrites=false
# Docker Compose MongoDB (replica set — transaction lar uchun)
# MONGODB_URI=mongodb://localhost:27017/bito?replicaSet=rs0
CORS_ORIGIN=http://localhost:3000
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=8h
PAYMENT_WEBHOOK_SECRET=whsec_change_me
NODE_ENV=development
